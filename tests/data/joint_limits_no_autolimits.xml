<mujoco model="joint_limits_no_autolimits">
    <compiler autolimits="false" angle="degree"/>
    <worldbody>
        <!-- Explicitly limited joint -->
        <body name="body1">
            <geom type="box" size="0.1 0.1 0.1"/>
            <body name="body2">
                <joint name="limited_joint" type="hinge" limited="true" range="-45 45"/>
                <geom type="box" size="0.1 0.1 0.1"/>
            </body>
        </body>

        <!-- Explicitly unlimited joint -->
        <body name="body3">
            <geom type="box" size="0.1 0.1 0.1"/>
            <body name="body4">
                <joint name="unlimited_joint" type="hinge" limited="false"/>
                <geom type="box" size="0.1 0.1 0.1"/>
            </body>
        </body>

        <!-- Direct-mode solreflimit should author Newton limit gains. -->
        <body name="body5">
            <geom type="box" size="0.1 0.1 0.1"/>
            <body name="body6">
                <joint name="direct_limit_joint" type="hinge" limited="true" range="-20 20" solreflimit="-12 -3"/>
                <geom type="box" size="0.1 0.1 0.1"/>
            </body>
        </body>

        <!-- Linear joints should not use angular per-degree scaling. -->
        <body name="body7">
            <geom type="box" size="0.1 0.1 0.1"/>
            <body name="body8">
                <joint name="linear_limit_joint" type="slide" limited="true" range="-0.2 0.4" solreflimit="0.04 0.5"/>
                <geom type="box" size="0.1 0.1 0.1"/>
            </body>
        </body>
    </worldbody>
</mujoco>
